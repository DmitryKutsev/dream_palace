BOT_TOKEN=
ADMIN_TELEGRAM_IDS=123456789
WEBHOOK_SECRET=replace-with-a-long-random-value
# Public HTTPS URL of the Mini App (…/app): tunnel URL locally, Function URL in prod.
WEBAPP_URL=

# Azure identity. Leave AZURE_CLIENT_ID empty locally to use Azure CLI credentials.
AZURE_CLIENT_ID=
AZURE_STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=dream-media

COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE_NAME=dream-palace
COSMOS_USERS_CONTAINER=users
COSMOS_DREAMS_CONTAINER=dreams

FOUNDRY_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_AGENT_NAME=dream-analyst
